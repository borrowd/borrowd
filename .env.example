# see CONTRIBUTING.md for descriptions of the different environment variables
DJANGO_SETTINGS_MODULE=borrowd.config.dev.django
DJANGO_SECRET_KEY=not-a-real-secret
BORROWD_BETA_ENABLED=False

# Web Push — generate once with:
VAPID_PRIVATE_KEY= vapid --gen
VAPID_PUBLIC_KEY=python -c "
                    from py_vapid import Vapid
                    from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat
                    import base64
                    v = Vapid.from_file('private_key.pem')
                    print(base64.urlsafe_b64encode(
                        v.private_key.public_key().public_bytes(Encoding.X962, PublicFormat.UncompressedPoint)
                    ).decode().rstrip('='))
                "
VAPID_ADMIN_EMAIL= a real email
