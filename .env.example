# see CONTRIBUTING.md for descriptions of the different environment variables
DJANGO_SETTINGS_MODULE=borrowd.config.dev.django
DJANGO_SECRET_KEY=not-a-real-secret
BORROWD_BETA_ENABLED=False

# Web Push (VAPID) — generate a keypair once with:
#   python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key.decode()); print(v.public_key.decode())"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_ADMIN_EMAIL=
